# Server
PORT=3000

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=put_meta_permanent_or_temp_token_here
WHATSAPP_PHONE_NUMBER_ID=put_phone_number_id_here
WHATSAPP_API_VERSION=v23.0
VERIFY_TOKEN=choose_any_secret_verify_token_here

# Optional: comma-separated allowed sender phone numbers in international format without +
# Example: 9677XXXXXXXX,9677YYYYYYYY
ALLOWED_NUMBERS=

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
SPREADSHEET_ID=put_google_sheet_id_here
SHEET_NAME=الورقة1
NAME_COLUMN=E
COLOR_COLUMN=D

# Bot logic
REPORT_DELAY_MINUTES=5
MATCH_WORD_COUNT=3